{
  "manifest_version": 3,
  "name": "Publisher Pricing Analyzer",
  "version": "1.2.0",
  "description": "تحلیل RPM موقعیت‌های تبلیغاتی یکتانت بر اساس داده‌های تاریخی",
  "permissions": ["activeTab", "scripting", "storage", "unlimitedStorage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Publisher Pricing Analyzer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar.html", "sidebar.js", "sidebar.css",
        "data/publisher_data.json"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
